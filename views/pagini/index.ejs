        <h4 class="mb-2 text-danger fw-bold"><i class="fa-solid fa-fire fa-beat"></i> SUPER OFERTĂ ACTIVĂ!</h4>
        <p class="fs-5 mb-1" style="color: #880e4f;">
            Ai <span id="of-reducere" class="fw-bold fs-3"></span>% REDUCERE pentru toate clasele din categoria: <span id="of-cat" class="fw-bold text-uppercase"></span>
        </p>
        <div class="mt-2 fs-5">
            Timp rămas: <span id="of-timer" class="badge bg-dark fs-4 ms-2 p-2 px-3">00:00</span>
        </div>
    </div>

    <script>
        let intervalOferta = null;
        async function incarcaOfertaAcasa() {
            try {
                let res = await fetch('/api/oferta');
                let oferta = await res.json();
                
                if (oferta) {
                    document.getElementById('banner-oferta').classList.remove('d-none');
                    document.getElementById('of-reducere').innerText = oferta.reducere;
                    document.getElementById('of-cat').innerText = oferta.categorie;
                    
                    let dataFinal = new Date(oferta['data-finalizare']).getTime();
                    if(intervalOferta) clearInterval(intervalOferta);
                    
                    intervalOferta = setInterval(() => {
                        let distanta = dataFinal - new Date().getTime();
                        
                        if (distanta <= 0) {
                            clearInterval(intervalOferta);
                            document.getElementById('banner-oferta').classList.add('d-none');
                            setTimeout(incarcaOfertaAcasa, 1500); // Oferta expiră, cerem alta nouă!
                            return;
                        }
                        
                        let minute = Math.floor((distanta % (1000 * 60 * 60)) / (1000 * 60));
                        let secunde = Math.floor((distanta % (1000 * 60)) / 1000);
                        let timerDiv = document.getElementById('of-timer');
                        
                        timerDiv.innerText = `${minute.toString().padStart(2, '0')}:${secunde.toString().padStart(2, '0')}`;
                        
                        // c. Ultimele 10 secunde - schimbă culoarea 
                        if (distanta < 10000) {
                            timerDiv.classList.replace('bg-dark', 'bg-danger');
                        } else {
                            timerDiv.classList.replace('bg-danger', 'bg-dark');
                        }
                    }, 1000);
                }
            } catch(e) {}
        }
        window.addEventListener('DOMContentLoaded', incarcaOfertaAcasa);
    </script>
    
